# ─── Signal Hunters — Environment Variables ───────────────────────────────────
# Copy file này thành .env và điền thông tin thực tế của bạn
# cp .env.example .env
#
# QUAN TRỌNG: Không commit file .env lên Git!
# File .gitignore đã có entry cho .env

# ══ Facebook Page Auto-Post ══════════════════════════════════════════════════

# FB_PAGE_TOKEN: Page Access Token (long-lived)
# Cách lấy:
#   1. Vào https://developers.facebook.com/ → tạo app hoặc dùng app sẵn có
#   2. Vào "Graph API Explorer" (https://developers.facebook.com/tools/explorer/)
#   3. Chọn App → Permission: pages_manage_posts, pages_read_engagement
#   4. Generate Token → copy User Access Token
#   5. Đổi sang Page Access Token:
#      GET https://graph.facebook.com/v19.0/me/accounts?access_token=USER_TOKEN
#      → Tìm page Signal Hunters → copy "access_token"
#   6. Để có long-lived token (không hết hạn), đổi qua:
#      GET https://graph.facebook.com/oauth/access_token
#          ?grant_type=fb_exchange_token
#          &client_id=APP_ID
#          &client_secret=APP_SECRET
#          &fb_exchange_token=SHORT_LIVED_PAGE_TOKEN
FB_PAGE_TOKEN=your_facebook_page_access_token_here

# FB_PAGE_ID: ID của Facebook Page Signal Hunters
# Cách lấy:
#   Vào https://www.facebook.com/YOUR_PAGE → Giới thiệu → Cuộn xuống → "ID trang"
#   Hoặc: GET https://graph.facebook.com/v19.0/me?access_token=PAGE_TOKEN
#   → copy trường "id"
FB_PAGE_ID=your_facebook_page_id_here

# ══ Tùy chọn thêm ═══════════════════════════════════════════════════════════

# Số giờ tối đa để coi bài là "mới" (default 48)
# MAX_AGE_HOURS=48

# Base URL của website (dùng để tạo link bài viết)
# SITE_BASE_URL=https://tanphat251196-max.github.io/signal-hunters-web
